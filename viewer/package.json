{
  "name": "projectlm-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "capture:preview": "node scripts/capture_preview.mjs",
    "generate:track-bg": "tsx scripts/generate_track_backgrounds.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts'",
    "test:integration": "node --import tsx --test 'test/integration/**/*.test.ts'",
    "test:smoke": "node tests/smoke/app_loads.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
