{
  "name": "projectlm-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts'",
    "test:integration": "node --import tsx --test 'test/integration/**/*.test.ts'",
    "benchmark:damage": "node --import tsx scripts/run_damage_endurance.mjs",
    "benchmark:damage:6h": "DURATION_HOURS=6 node --import tsx scripts/run_damage_endurance.mjs"
  },
  "dependencies": {
    "@projectlm/native": "file:../bindings/node",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
