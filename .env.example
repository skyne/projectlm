# Copy to .env and fill in (never commit .env)
GEMINI_API_KEY=your_key_here
# Get key from https://aistudio.google.com/apikey (usually starts with AIza...)
# Image models require billing on the GCP project if free-tier quota shows limit: 0.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# auto | gemini | pollinations
IMAGE_GEN_BACKEND=auto
